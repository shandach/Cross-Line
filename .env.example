# ═══════════════════════════════════════════════════
# Client Counter Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Branch identification (for multi-branch scaling)
# Each branch gets a unique ID — used in cloud DB for filtering
BRANCH_ID=branch_01
BRANCH_NAME=Your Branch Name

# RTSP Camera URL (entrance camera)
# Use 0 for local webcam, or rtsp://user:pass@IP:554/stream for IP camera
CAMERA_URL=0
CAMERA_NAME=Entrance Camera

# Work shift (Tashkent time, UTC+5)
WORK_START=09:00
WORK_END=17:00

# AI Settings
YOLO_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.35

# Frame resolution
FRAME_WIDTH=1920
FRAME_HEIGHT=1080

# Cloud PostgreSQL — paste your Railway DSN here
DB_DSN=

# Display
FULLSCREEN_MODE=false
